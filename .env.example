# =============================================================
# GEUClubs — Environment Variables
# =============================================================
# Copy this file and rename it to .env
# Fill in your actual values — never commit .env to GitHub
# =============================================================


# -------------------------------------------------------------
# FIREBASE
# Get these from: Firebase Console → your project →
# Project Settings → General → Your apps → SDK setup
# -------------------------------------------------------------

VITE_FIREBASE_API_KEY=AIzaSy_your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX


# -------------------------------------------------------------
# CLOUDINARY  (used for image uploads — event posters, club logos)
# Get these from: cloudinary.com → Dashboard
# Upload preset: Settings → Upload → Upload presets
# Make sure the preset Signing Mode is set to "Unsigned"
# -------------------------------------------------------------

VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=preset_name_here


# =============================================================
# VERCEL DEPLOYMENT
# Add all the above variables in:
# Vercel → your project → Settings → Environment Variables
# Select all three environments: Production, Preview, Development
# After adding, redeploy for changes to take effect
# =============================================================
